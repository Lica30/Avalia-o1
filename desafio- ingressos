alunos = int(input("Digite a quantidade de alunos: "))
monitores = int(input("Digite a quantidade de monitores: "))
convidados = int(input("Digite a quantidade de convidados: "))

total = alunos + monitores + convidados

if total <= 100:
    print("O total de pessoas pode ser acomodado dentro dos 100 ingressos disponíveis.")
else:
    print("O total de pessoas não pode ser acomodado, pois ultrapassa os 100 ingressos disponíveis.")

if convidados <= 20:
    print("O número de convidados está dentro do limite de 20.")
else:
    print("O número de convidados ultrapassa o limite de 20.")